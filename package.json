{
  "name": "actionpad",
  "version": "0.1.8",
  "private": true,
  "type": "module",
  "scripts": {
    "actionpad": "node scripts/actionpad.mjs",
    "actionpad:doctor": "node scripts/actionpad.mjs doctor",
    "dev": "VITE_ACTIONPAD_RUNTIME_URL=http://127.0.0.1:43217 vite --host 127.0.0.1",
    "dev:all": "node scripts/dev-all.mjs",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b --noEmit",
    "mcp:http": "tsx runtime/mcp/httpMain.ts",
    "mcp:start": "tsx runtime/mcp/stdioMain.ts",
    "release:new": "node scripts/release-new.mjs",
    "release:pack": "node scripts/create-release-tarball.mjs",
    "runtime:dev": "ACTIONPAD_RUNTIME_PORT=43217 tsx runtime/main.ts",
    "runtime:start": "tsx runtime/main.ts",
    "runtime:test": "vitest run --environment node runtime",
    "web:start": "node scripts/serve-dist.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.12.2",
    "@openai/codex-sdk": "^0.135.0",
    "@vitejs/plugin-react": "^4.3.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.0",
    "ws": "^8.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "jsdom": "^24.1.1",
    "tsx": "^4.22.3",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
